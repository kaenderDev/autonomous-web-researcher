# ==============================================================================
#  ResearchAgent Pro — Environment Configuration
#  Copy this file to `.env` and fill in your secrets.
#  NEVER commit your real `.env` file to version control.
# ==============================================================================

# --- LLM Provider ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Search Provider ---
SERPER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Agent Behaviour ---
# Model to use for synthesis (claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5)
LLM_MODEL=claude-sonnet-4-6

# Maximum number of search results to fetch per query
MAX_SEARCH_RESULTS=10

# Maximum number of URLs to scrape concurrently
MAX_CONCURRENT_SCRAPERS=5

# Timeout (seconds) for each individual HTTP request
HTTP_TIMEOUT=20

# Maximum retry attempts with exponential backoff for HTTP failures
MAX_RETRIES=4

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
